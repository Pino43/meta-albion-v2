# 알비온 Gameinfo API 베이스 URL (지역별)
# Europe (기본): https://gameinfo.albiononline.com/api/gameinfo
# Americas: https://gameinfo-ams.albiononline.com/api/gameinfo
# Asia: https://gameinfo-sgp.albiononline.com/api/gameinfo
ALBION_GAMEINFO_BASE_URL=https://gameinfo.albiononline.com/api/gameinfo

# 초당 최대 요청 수 (서버 부하 방지)
ALBION_RATE_LIMIT_PER_SEC=5

# HTTP 타임아웃(초)
ALBION_HTTP_TIMEOUT_SEC=30
