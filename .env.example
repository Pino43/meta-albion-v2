# Albion Gameinfo API base URL (single-region tools only).
# Europe: https://gameinfo.albiononline.com/api/gameinfo
# Americas: https://gameinfo-ams.albiononline.com/api/gameinfo
# Asia: https://gameinfo-sgp.albiononline.com/api/gameinfo
ALBION_GAMEINFO_BASE_URL=https://gameinfo.albiononline.com/api/gameinfo

# HTTP controls.
ALBION_RATE_LIMIT_PER_SEC=5
ALBION_HTTP_TIMEOUT_SEC=30
ALBION_HTTP_MAX_RETRIES=3
ALBION_HTTP_RETRY_BASE_DELAY_SEC=1.0

# PostgreSQL.
# Local docker-compose default:
# postgresql://albion:albion@localhost:5432/albion
# Railway: set this from the Railway Postgres service's DATABASE_URL variable.
DATABASE_URL=postgresql://albion:albion@localhost:5432/albion
DATABASE_CONNECT_MAX_RETRIES=10
DATABASE_CONNECT_RETRY_DELAY_SEC=3

# /events collector controls.
COLLECT_EVENTS_LIMIT=51
COLLECT_MAX_PAGES=10
COLLECT_REGIONS=europe,americas,asia
COLLECT_POLL_INTERVAL_SEC=60
COLLECT_ERROR_BACKOFF_SEC=30
COLLECT_NORMALIZE_AFTER_ROUND=true
COLLECT_AGGREGATE_AFTER_ROUND=true
COLLECT_RETENTION_AFTER_ROUND=true
NORMALIZE_BATCH_SIZE=1000
AGGREGATE_LOOKBACK_DAYS=3
RAW_EVENTS_RETENTION_DAYS=10
DAILY_AGGREGATE_RETENTION_DAYS=90
COLLECTOR_RUN_RETENTION_DAYS=30

# Read-only API controls.
# Railway provides PORT automatically for deployed services.
PORT=8000
